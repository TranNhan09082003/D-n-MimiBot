# =====================================================================
# MIMI BOT — biến môi trường (đặt qua panel Pterodactyl/VibeHost, KHÔNG commit .env thật)
# ---------------------------------------------------------------------
# LƯU Ý: token Discord của bot KHÔNG đặt ở đây — bot đọc từ config.json
# (trường "token" và "clientId"). File này chỉ dành cho Internal API + tùy chọn runtime.
# =====================================================================

# --- Internal API (để website gọi vào bot) ---
# Service token bảo mật. PHẢI TRÙNG với MIMI_API_TOKEN ở phía web.
# Sinh chuỗi ngẫu nhiên mạnh, ví dụ:  openssl rand -hex 32
# Nếu để TRỐNG, Internal API sẽ KHÔNG khởi động (an toàn — tránh mở cổng không xác thực).
#
# LƯU Ý QUAN TRỌNG: bot KHÔNG dùng dotenv, nên file .env này KHÔNG được đọc tự động.
# Biến ở đây chỉ có tác dụng khi panel Pterodactyl/VibeHost inject thẳng vào tiến trình.
# Nếu panel không inject được, hãy đặt token trong config.json thay vì ở đây:
#     "mimiApiToken": "<token>"
# (bot luôn đọc config.json — đây là cách chắc chắn nhất).
MIMI_API_TOKEN=

# Cổng lắng nghe của Internal API (mặc định 8787).
MIMI_API_PORT=8787

# Địa chỉ bind. Trên cùng một máy với web, nên dùng 127.0.0.1 để không mở ra ngoài.
# Nếu web và bot khác máy, để 0.0.0.0 và CHẶN cổng này bằng firewall, chỉ mở cho IP của web.
MIMI_API_HOST=127.0.0.1

# --- Tùy chọn ---
# Đường dẫn ffmpeg nếu không nằm trong PATH (để trống nếu đã có sẵn).
FFMPEG_PATH=
