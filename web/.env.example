# =====================================================================
# MIMI WEBSITE — biến môi trường (KHÔNG commit file .env thật)
# Sao chép file này thành .env.local (dev) hoặc .env (production)
# =====================================================================

# --- Thông tin thương hiệu / liên kết công khai (an toàn để lộ ra client) ---
NEXT_PUBLIC_BOT_NAME=Mimi
NEXT_PUBLIC_BOT_CLIENT_ID=
NEXT_PUBLIC_BOT_INVITE_URL=
NEXT_PUBLIC_DISCORD_SUPPORT_URL=https://discord.gg/cn535DxCn7
# URL công khai của website (dùng cho SEO, OAuth redirect nội bộ, metadata)
NEXT_PUBLIC_SITE_URL=https://mimi.example.vn

# --- Kết nối tới Internal API của bot (CHỈ dùng ở server-side) ---
# URL nội bộ tới bot (VibeHost). KHÔNG để lộ ra client.
BOT_API_INTERNAL_URL=http://127.0.0.1:8787
# Phải TRÙNG với MIMI_API_TOKEN đặt ở phía bot.
MIMI_API_TOKEN=

# --- Discord OAuth2 (Authorization Code Flow) ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Ví dụ: https://mimi.example.vn/api/auth/callback
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/callback

# --- Bảo mật session ---
# Chuỗi ngẫu nhiên >= 32 ký tự. Sinh bằng:  openssl rand -hex 32
AUTH_SECRET=
